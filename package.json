{
  "name": "hangar",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "VRChat .unitypackage カタログ + GUID遡及検出 + 忠実プレビュー (VRChat非公式・ローカル限定)",
  "main": "app/main.cjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.ts",
    "gui": "electron .",
    "portable": "node build-portable.mjs",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "tar-stream": "^3.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/tar-stream": "^3.1.3",
    "electron": "^42.3.2",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "build": {
    "appId": "io.github.hangar.app",
    "productName": "Hangar",
    "copyright": "Copyright (c) 2026 Hangar contributors",
    "asar": false,
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "app/**/*.cjs",
      "app/**/*.html",
      "dist/**/*",
      "render-template/**/*",
      "package.json",
      "LICENSE",
      "README.md",
      "PRIVACY.md",
      "THIRD_PARTY_NOTICES.md"
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "Hangar-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Hangar-${version}-setup.exe"
    }
  }
}
